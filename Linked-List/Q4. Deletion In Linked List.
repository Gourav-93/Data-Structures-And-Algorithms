class Node {
    int data;
    Node next;

    public Node(int d) {
        data = d;
        next = null;
    }
}

public class Deletion {
    public static Node AddAtStart(Node Head, int data) {
        Node newNode = new Node(data);
        if (Head == null) {
            Head = newNode;
        } else {
            newNode.next = Head;
            Head = newNode;
        }
        return Head;
    }

    public static Node AddAtLast(Node Head, int data) {
        Node newNode = new Node(data);
        if (Head == null) {
            System.out.println("Linked List Was Empty..!");
        } else {
            Node current = Head;
            while (current.next != null) {
                current = current.next;
            }
            current.next = newNode;
        }
        return Head;
    }

    public static void AddAtPOS(Node Head, int data, int pos) {
        Node newNode = new Node(data);
        if (Head == null) {
            System.out.println("You Dont Have A Enough Data Linked List..!");
        } else {
            Node current = Head;
            for (int i = 0; i < pos - 2; i++) {
                current = current.next;
            }
            newNode.next = current.next;
            current.next = newNode;
        }
    }

    public static Node DeleteAtStart(Node Head) {
        if (Head == null) {
            System.out.println("Linked List Was Empty..!");
            return null;
        } else {
            System.out.println("Frist Node Was Deleted : ");
            return Head.next;
        }
    }

    public static Node DeleteAtLast(Node Head) {
        if (Head == null) {
            System.out.println("Linked List Was Empty..!");
            return null;
        } else {
            Node current = Head;
            while (current.next != null) {
                current = current.next;
            }
            System.out.println("Last Node Was Deleted : ");
            current.next = null;
        }
        return Head;
    }

    public static void getList(Node Head) {
        if (Head == null) {
            System.out.println("Linked List Was Empty..!");
        } else {
            Node current = Head;
            while (current != null) {
                System.out.print(current.data);
                System.out.print(" -> ");
                current = current.next;
            }
            System.out.println("null");
        }
    }

    public static void main(String[] args) {
        Node Head = null;
        Head = AddAtStart(Head, 10);
        getList(Head);
        AddAtLast(Head, 20);
        getList(Head);
        AddAtPOS(Head, 15, 2);
        getList(Head);
        Head = AddAtStart(Head, 5);
        getList(Head);
        AddAtLast(Head, 25);
        getList(Head);
        Head = DeleteAtStart(Head);
        getList(Head);
        Head = DeleteAtLast(Head);
        getList(Head);
    }
}
