import java.util.Arrays;
public class Main {
    public static void ShotArray(int arr[]) {
        int n = arr.length;
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n - 1; j++) {
                if (arr[j] > arr[j + 1]) {
                    int c = arr[j];
                    arr[j] = arr[j + 1];
                    arr[j + 1] = c;
                }
            }
        }
    }

    public static void main(String[] args) {
        int arr[] = { 9, 4, 6, 3, 7, 5, 0, 2 };
        ShotArray(arr);
        System.out.println("Shoted Array Are The : " + Arrays.toString(arr));
        int k = 3;
        int kthSmallest = arr[k - 1];
        int kthLargest = arr[arr.length - k];
        System.out.println(k + "rd Smallest element: " + kthSmallest);
        System.out.println(k + "rd Largest element: " + kthLargest);

    }
}
